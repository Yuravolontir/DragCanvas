@startuml
left to right direction

actor User as UserLeft
actor Admin
actor Timer
actor User as UserRight

rectangle "dragcanvas.com" {

  ' ===== User (left) =====
  UserLeft -- (Register / Login)
  UserLeft -- (Select Template)
  UserLeft -- (Edit Template)
  UserLeft -- (Drag & Drop Elements)
  UserLeft -- (Edit Text / Images / Colors)
  UserLeft -- (Use AI Tools)
  UserLeft -- (Save Website as Draft)
  UserLeft -- (Publish Website)
  UserLeft -- (Restore Previous Version)
  UserLeft -- (Add Custom Code)
  UserLeft -- (Manage Domain / Subdomain)
  UserLeft -- (Receive Notification Emails)

  (Use AI Tools) -- (Generate Text) : <<include>>
  (Use AI Tools) -- (Generate Images) : <<include>>
  (Use AI Tools) -- (Improve Layout) : <<include>>

  ' ===== Admin =====
  Admin -- (Admin Login)
  Admin -- (Create Template)
  Admin -- (Edit Template)
  Admin -- (Delete Template)
  Admin -- (Manage Template Categories)
  Admin -- (Add Drag & Drop Elements)
  Admin -- (Configure Widget Properties)
  Admin -- (View System Statistics)

  ' ===== Timer =====
  Timer -- (Send Scheduled Emails)
  Timer -- (Send Birthday Emails)
  Timer -- (Send System Updates)

  ' ===== User (right – receiver) =====
  (Send Scheduled Emails) --- UserRight
  (Send Birthday Emails) --- UserRight
  (Send System Updates) --- UserRight
}

@enduml
